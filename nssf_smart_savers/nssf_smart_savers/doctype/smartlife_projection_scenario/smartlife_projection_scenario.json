{
  "name": "SmartLife Projection Scenario",
  "module": "Nssf Smart Savers",
  "doctype": "DocType",
  "engine": "InnoDB",
  "autoname": "hash",
  "is_submittable": 0,
  "track_changes": 0,
  "custom": 0,
  "field_order": [
    "scenario_label", "segment", "goal", "frequency", "initial_deposit",
    "periodic_contribution", "years", "annual_rate", "total_contributions",
    "projected_value", "indicative_return", "frequency_label", "periods_per_year",
    "session_id", "is_demo", "demo_notice"
  ],
  "fields": [
    {"fieldname": "scenario_label", "fieldtype": "Data", "label": "Scenario Label"},
    {"fieldname": "segment", "fieldtype": "Data", "label": "Segment"},
    {"fieldname": "goal", "fieldtype": "Data", "label": "Goal"},
    {"fieldname": "frequency", "fieldtype": "Data", "label": "Frequency"},
    {"fieldname": "initial_deposit", "fieldtype": "Currency", "label": "Initial Deposit"},
    {"fieldname": "periodic_contribution", "fieldtype": "Currency", "label": "Periodic Contribution"},
    {"fieldname": "years", "fieldtype": "Int", "label": "Years"},
    {"fieldname": "annual_rate", "fieldtype": "Float", "label": "Annual Rate", "default": "10"},
    {"fieldname": "total_contributions", "fieldtype": "Currency", "label": "Total Contributions"},
    {"fieldname": "projected_value", "fieldtype": "Currency", "label": "Projected Value"},
    {"fieldname": "indicative_return", "fieldtype": "Currency", "label": "Indicative Return"},
    {"fieldname": "frequency_label", "fieldtype": "Data", "label": "Frequency Label"},
    {"fieldname": "periods_per_year", "fieldtype": "Int", "label": "Periods Per Year"},
    {"fieldname": "session_id", "fieldtype": "Data", "label": "Session ID"},
    {"fieldname": "is_demo", "fieldtype": "Check", "label": "Is Demo", "default": "1"},
    {"fieldname": "demo_notice", "fieldtype": "Small Text", "label": "Demo Notice"}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "All", "read": 0, "write": 0, "create": 0, "delete": 0}
  ]
}
