{
  "name": "SmartLife Demo Lead",
  "module": "Nssf Smart Savers",
  "doctype": "DocType",
  "engine": "InnoDB",
  "autoname": "naming_series:",
  "naming_series": "SL-LEAD-.YYYY.-.####",
  "is_submittable": 0,
  "track_changes": 1,
  "custom": 0,
  "field_order": [
    "naming_series",
    "segment", "goal", "goal_label", "target_amount", "years", "frequency",
    "initial_deposit", "source_of_income", "industry", "country",
    "staff_assisted", "journey_type", "plan_generated", "payment_simulated",
    "dropoff_step", "lead_stage",
    "section_personal",
    "first_name", "last_name", "gender",
    "date_of_birth", "age_years", "age_band", "birthday_month", "birthday_day",
    "primary_phone", "alt_phone", "email_address",
    "preferred_contact_channel", "consent_to_contact",
    "section_lifecycle",
    "lead_status", "onboarding_stage", "lead_temperature", "lead_score",
    "next_best_action", "assigned_staff",
    "last_contacted_on", "next_follow_up_on", "follow_up_outcome", "drop_off_reason",
    "section_attribution",
    "source_route", "campaign_source", "campaign_medium", "campaign_name",
    "section_journey_flags",
    "projection_viewed", "checkout_started", "payment_completed",
    "analytics_labels", "created_session_id", "demo_note"
  ],
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Series", "label": "Series", "options": "SL-LEAD-.YYYY.-.####"},
    {"fieldname": "segment", "fieldtype": "Data", "label": "Segment", "reqd": 1},
    {"fieldname": "goal", "fieldtype": "Data", "label": "Goal", "reqd": 0},
    {"fieldname": "goal_label", "fieldtype": "Data", "label": "Goal Label"},
    {"fieldname": "target_amount", "fieldtype": "Currency", "label": "Target Amount"},
    {"fieldname": "years", "fieldtype": "Int", "label": "Years"},
    {"fieldname": "frequency", "fieldtype": "Data", "label": "Frequency"},
    {"fieldname": "initial_deposit", "fieldtype": "Currency", "label": "Initial Deposit"},
    {"fieldname": "source_of_income", "fieldtype": "Data", "label": "Source of Income"},
    {"fieldname": "industry", "fieldtype": "Data", "label": "Industry"},
    {"fieldname": "country", "fieldtype": "Data", "label": "Country", "default": "Uganda"},
    {"fieldname": "staff_assisted", "fieldtype": "Check", "label": "Staff Assisted"},
    {"fieldname": "journey_type", "fieldtype": "Data", "label": "Journey Type"},
    {"fieldname": "plan_generated", "fieldtype": "Check", "label": "Plan Generated"},
    {"fieldname": "payment_simulated", "fieldtype": "Check", "label": "Payment Simulated"},
    {"fieldname": "dropoff_step", "fieldtype": "Data", "label": "Dropoff Step"},
    {"fieldname": "lead_stage", "fieldtype": "Data", "label": "Lead Stage", "default": "New"},
    {"fieldname": "section_personal", "fieldtype": "Section Break", "label": "Personal Details"},
    {"fieldname": "first_name", "fieldtype": "Data", "label": "First Name"},
    {"fieldname": "last_name", "fieldtype": "Data", "label": "Last Name"},
    {"fieldname": "gender", "fieldtype": "Data", "label": "Gender"},
    {"fieldname": "date_of_birth", "fieldtype": "Date", "label": "Date of Birth"},
    {"fieldname": "age_years", "fieldtype": "Int", "label": "Age (Years)"},
    {"fieldname": "age_band", "fieldtype": "Data", "label": "Age Band"},
    {"fieldname": "birthday_month", "fieldtype": "Int", "label": "Birthday Month"},
    {"fieldname": "birthday_day", "fieldtype": "Int", "label": "Birthday Day"},
    {"fieldname": "primary_phone", "fieldtype": "Data", "label": "Primary Phone"},
    {"fieldname": "alt_phone", "fieldtype": "Data", "label": "Alternative Phone"},
    {"fieldname": "email_address", "fieldtype": "Data", "label": "Email Address"},
    {"fieldname": "preferred_contact_channel", "fieldtype": "Data", "label": "Preferred Contact Channel"},
    {"fieldname": "consent_to_contact", "fieldtype": "Check", "label": "Consent to Contact"},
    {"fieldname": "section_lifecycle", "fieldtype": "Section Break", "label": "Lead Lifecycle"},
    {"fieldname": "lead_status", "fieldtype": "Select", "label": "Lead Status",
      "options": "New\nPersonal Details Captured\nGoal Selected\nProjection Viewed\nCheckout Started\nPayment Pending\nPayment Completed\nStaff Follow-up Required\nContacted\nConverted\nDormant\nDisqualified",
      "default": "New"},
    {"fieldname": "onboarding_stage", "fieldtype": "Data", "label": "Onboarding Stage"},
    {"fieldname": "lead_temperature", "fieldtype": "Select", "label": "Lead Temperature",
      "options": "\nHot\nWarm\nCold"},
    {"fieldname": "lead_score", "fieldtype": "Int", "label": "Lead Score", "default": "0"},
    {"fieldname": "next_best_action", "fieldtype": "Data", "label": "Next Best Action"},
    {"fieldname": "assigned_staff", "fieldtype": "Data", "label": "Assigned Staff"},
    {"fieldname": "last_contacted_on", "fieldtype": "Date", "label": "Last Contacted On"},
    {"fieldname": "next_follow_up_on", "fieldtype": "Date", "label": "Next Follow-up On"},
    {"fieldname": "follow_up_outcome", "fieldtype": "Data", "label": "Follow-up Outcome"},
    {"fieldname": "drop_off_reason", "fieldtype": "Data", "label": "Drop-off Reason"},
    {"fieldname": "section_attribution", "fieldtype": "Section Break", "label": "Attribution"},
    {"fieldname": "source_route", "fieldtype": "Data", "label": "Source Route"},
    {"fieldname": "campaign_source", "fieldtype": "Data", "label": "Campaign Source"},
    {"fieldname": "campaign_medium", "fieldtype": "Data", "label": "Campaign Medium"},
    {"fieldname": "campaign_name", "fieldtype": "Data", "label": "Campaign Name"},
    {"fieldname": "section_journey_flags", "fieldtype": "Section Break", "label": "Journey Flags"},
    {"fieldname": "projection_viewed", "fieldtype": "Check", "label": "Projection Viewed"},
    {"fieldname": "checkout_started", "fieldtype": "Check", "label": "Checkout Started"},
    {"fieldname": "payment_completed", "fieldtype": "Check", "label": "Payment Completed"},
    {"fieldname": "analytics_labels", "fieldtype": "Small Text", "label": "Analytics Labels"},
    {"fieldname": "created_session_id", "fieldtype": "Data", "label": "Session ID"},
    {"fieldname": "demo_note", "fieldtype": "Small Text", "label": "Demo Note", "default": "SmartLife Flexi Demo. Prototype environment. Do not enter real NSSF member data."}
  ],
  "permissions": [
    {"role": "System Manager", "read": 1, "write": 1, "create": 1, "delete": 1},
    {"role": "All", "read": 0, "write": 0, "create": 0, "delete": 0}
  ]
}
