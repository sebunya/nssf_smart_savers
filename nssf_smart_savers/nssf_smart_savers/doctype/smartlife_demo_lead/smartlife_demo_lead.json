    {"fieldname": "frequency", "fieldtype": "Data", "label": "Frequency"},
    {"fieldname": "initial_deposit", "fieldtype": "Currency", "label": "Initial Deposit"},
    {"fieldname": "source_of_income", "fieldtype": "Data", "label": "Source of Income"},
    {"fieldname": "industry", "fieldtype": "Data", "label": "Industry"},
    {"fieldname": "country", "fieldtype": "Data", "label": "Country", "default": "Uganda"},
    {"fieldname": "staff_assisted", "fieldtype": "Check", "label": "Staff Assisted"},
    {"fieldname": "journey_type", "fieldtype": "Data", "label": "Journey Type"},
    {"fieldname": "plan_generated", "fieldtype": "Check", "label": "Plan Generated"},
    {"fieldname": "payment_simulated", "fieldtype": "Check", "label": "Payment Simulated"},
    {"fieldname": "dropoff_step", "fieldtype": "Data", "label": "Dropoff Step"},
    {"fieldname": "lead_stage", "fieldtype": "Data", "label": "Lead Stage", "default": "New"},
